    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0" />
    <rgba haze="0.15 0.25 0.35 1" />
    <global azimuth="120" elevation="-20" />
  </visual>
  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072" />
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300" />
    <!-- DICT_4X4_50, ID 0. Generated by scripts/generate_aruco_marker.py.
         Physical edge length is configured as 40 mm in both this geom and
         configs/aruco_goal_localization.json. -->
    <texture type="2d" name="aruco_goal_id0" file="assets/aruco/aruco_4x4_50_id0.png" />
    <mesh name="aruco_goal_plane" file="aruco/aruco_marker_plane.obj" scale="0.02 0.02 0.02" />
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2" />
    <material name="aruco_goal_id0" texture="aruco_goal_id0" texuniform="true" texrepeat="1 1" specular="0" shininess="0" />
  </asset>
  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true" />
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane" />
    <body name="table" pos="0.45 0 0">
      <geom name="table_top" type="box" pos="0.2 0 0.27" size="0.45 0.35 0.03" rgba="0.55 0.42 0.28 1" />
      <geom name="table_leg_1" type="box" pos="0.55 0.25 0.12" size="0.03 0.03 0.12" rgba="0.35 0.28 0.2 1" />
      <geom name="table_leg_2" type="box" pos="0.55 -0.25 0.12" size="0.03 0.03 0.12" rgba="0.35 0.28 0.2 1" />
      <geom name="table_leg_3" type="box" pos="-0.15 0.25 0.12" size="0.03 0.03 0.12" rgba="0.35 0.28 0.2 1" />
      <geom name="table_leg_4" type="box" pos="-0.15 -0.25 0.12" size="0.03 0.03 0.12" rgba="0.35 0.28 0.2 1" />
    </body>
    <body name="object" pos="0.45 0 0.315">
      <joint name="object_freejoint" type="free" />
      <geom name="object_geom" type="box" size="0.015 0.015 0.015" mass="0.02" contype="3" conaffinity="3" friction="3.0 0.02 0.001" solimp="0.95 0.99 0.001" solref="0.004 1" rgba="0.9 0.15 0.1 1" />
      <site name="object_site" type="sphere" size="0.008" rgba="1 1 0 1" />
    </body>
    <body name="goal" mocap="true" pos="0.25 0.25 0.315">
      <!-- Marker face is 0.2 mm above the table to avoid z-fighting. Its XY
           center follows the goal mocap body. The original goal site remains
           as a small diagnostic/truth marker at the cube center. Neither geom
           participates in contact physics. -->
      <geom name="aruco_goal_white_backing" type="box" pos="0 0 -0.01495" size="0.024 0.024 0.00005" rgba="1 1 1 1" contype="0" conaffinity="0" group="2" />
      <!-- The mesh top is +0.2 mm from its local origin after scaling, so
           -15.0 mm puts the textured marker plane at world z=0.3002 m. -->
      <geom name="aruco_goal_marker" type="mesh" mesh="aruco_goal_plane" pos="0 0 -0.015" material="aruco_goal_id0" contype="0" conaffinity="0" group="2" />
      <site name="goal_site" type="sphere" size="0.003" rgba="0.1 0.8 0.2 0.65" />
    </body>
    <body name="mocap_target" mocap="true" pos="-0.13399739 0.49199973 0.37000037" quat="4.7702898e-12 0.70710808 0.70710548 2.5973482e-06">
      <site name="mocap_target_site" type="sphere" size="0.006" rgba="0.1 0.4 1 0.40" />
    </body>

  <!-- IK test: visual mocap target only; no TCP weld. -->
  <keyframe>
    <!-- qpos="-1.5708 -1.5708 1.5708 -1.5708 -1.5708 0 0 0 0 0 0 0 0.45 0 0.315 1 0 0 0"-->
    <!-- PPO task start: preserve the joint distribution used by training. -->
    <key name="home" qpos="-1.5708 -1.5708 1.5708 -1.5708 -1.5708 0 0 0 0 0 0 0 0.45 0 0.315 1 0 0 0" ctrl="-1.5708 -1.5708 1.5708 -1.5708 -1.5708 0 0" />
    <!-- Natural pre-policy RGB-D acquisition pose for the corrected adapter
         indexing. It stays close to the original bent-arm posture while
         covering the complete randomized cube workspace. Runtime code must
         read only the first six arm coordinates; loading this whole keyframe
         would overwrite the episode's randomized object state. -->
    <key name="camera_observe" qpos="-3.50356411 -1.39121562 0.03083238 -0.38197572 -1.56229418 -0.34007296 0 0 0 0 0 0 0.45 0 0.315 1 0 0 0" ctrl="-3.50356411 -1.39121562 0.03083238 -0.38197572 -1.56229418 -0.34007296 0" />
  </keyframe>
